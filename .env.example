# Connexion PostgreSQL (locale ou distante)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp"

# Secret JWT (genere automatiquement au premier setup s'il vaut la valeur par defaut)
JWT_SECRET="change-me-at-first-run-this-will-be-replaced-by-a-random-secret"

# Duree de validite du JWT (format ms : "12h", "7d", "30m", ...)
JWT_EXPIRES_IN="12h"

# Dossier local pour les uploads (datasheets, logos, etc.)
STORAGE_DIR="./storage"
